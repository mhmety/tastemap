# Application
APP_NAME=TasteMap
DEBUG=true

# PostgreSQL
POSTGRES_USER=tastemap
POSTGRES_PASSWORD=tastemap
POSTGRES_DB=tastemap

# SQLAlchemy connection string (used by the API and Alembic)
DATABASE_URL=postgresql://tastemap:tastemap@db:5432/tastemap

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
